# =============================================================================
# Environment Variables
# =============================================================================
# Copy this file to .env and configure your values

# Application
ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=FastAPI Application
APP_DEBUG=true

# Database (configure in config/settings.yaml)
# For SQLite: database.type=sqlite
# For MySQL: database.type=mysql
# For PostgreSQL: database.type=postgresql

# Redis (configure in config/settings.yaml)
# To disable Redis: redis.enabled=false

# =============================================================================
# Authentication (configure in config/settings.yaml)
# =============================================================================
# Generate a secret key with:
# python -c "from jose import jwt; print(jwt.encode({'test': 'test'}, 'secret', algorithm='HS256'))"
# AUTH_SECRET_KEY=your-secret-key-change-in-production
# AUTH_ALGORITHM=HS256
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Optional: Override YAML settings with environment variables
# =============================================================================
# Example overrides:
# DATABASE_TYPE=postgresql
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_password
# DATABASE_DATABASE=app_db

# REDIS_ENABLED=true
# REDIS_MODE=cluster
